# Ensure Thai text in HTML/JS/JSON is served as UTF-8
AddDefaultCharset UTF-8

<IfModule mod_mime.c>
  AddCharset UTF-8 .html .htm .css .js .json .php .xml .svg
</IfModule>

# ลดปัญหาแคชค้าง — HTML และ data-fallback ต้อง revalidate ทุกครั้ง
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "(data-fallback|tt-cache-version)\.js$">
    Header set Cache-Control "no-cache, must-revalidate"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>
